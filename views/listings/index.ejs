<% layout("/layouts/boilerplate.ejs") %>

<%
  const categories = [
    { label: "Trending", value: "Trending", icon: "fa-solid fa-fire" },
    { label: "Rooms", value: "Rooms", icon: "fa-solid fa-bed" },
    { label: "Mountains", value: "Mountains", icon: "fa-solid fa-mountain" },
    { label: "Castles", value: "Castles", icon: "fa-brands fa-fort-awesome" },
    { label: "Beach", value: "Amazing Pools", icon: "fa-solid fa-umbrella-beach" },
    { label: "Unique stays", value: "Domes", icon: "fa-solid fa-sparkles" },
    { label: "Desert", value: "Arctic", icon: "fa-regular fa-snowflake" },
    { label: "Countryside", value: "Farms", icon: "fa-solid fa-wheat-awn" },
    { label: "Lakefront", value: "Boats", icon: "fa-solid fa-water" }
  ];
%>

<style>
  .home-page {
    background: #ffffff;
  }

  .home-shell {
    max-width: 2520px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .hero-band {
    background: linear-gradient(180deg, #f7f7f7 0%, #ffffff 100%);
    box-shadow: inset 0 -1px 0 #ebebeb;
  }

  .hero-content {
    padding: 4.5rem 0 3.5rem;
    text-align: center;
  }

  .hero-title {
    font-size: clamp(3rem, 6vw, 4.8rem);
    line-height: 1.03;
    letter-spacing: -0.05em;
    margin: 0;
    font-weight: 600;
  }

  .hero-subtitle {
    max-width: 680px;
    margin: 1.4rem auto 0;
    color: #6b7280;
    font-size: 1.45rem;
  }

  .hero-search {
    max-width: 920px;
    margin: 2.2rem auto 0;
  }

  .hero-search__form {
    display: flex;
    align-items: center;
    gap: 1rem;
    background: #ffffff;
    border: 1px solid #ececec;
    border-radius: 999px;
    padding: 0.65rem 0.8rem 0.65rem 1.75rem;
    box-shadow: 0 10px 30px rgba(15, 23, 42, 0.12);
  }

  .hero-search__input {
    flex: 1;
    border: none;
    background: transparent;
    font-size: 1.45rem;
    color: #222222;
  }

  .hero-search__input:focus {
    outline: none;
  }

  .hero-search__submit {
    width: 4.4rem;
    height: 4.4rem;
    border: none;
    border-radius: 999px;
    background: #ff385c;
    color: #ffffff;
    font-size: 1.35rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .hero-search__submit:hover {
    background: #e31c5f;
  }

  .category-strip {
    border-bottom: 1px solid #ebebeb;
    background: #ffffff;
  }

  .category-strip__row {
    display: flex;
    align-items: center;
    gap: 1rem;
    overflow-x: auto;
    padding: 1.35rem 0 1rem;
    scrollbar-width: none;
  }

  .category-strip__row::-webkit-scrollbar {
    display: none;
  }

  .category-chip {
    flex: 0 0 auto;
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    gap: 0.45rem;
    min-width: 78px;
    padding-bottom: 0.85rem;
    border-bottom: 2px solid transparent;
    color: #717171;
    text-decoration: none;
  }

  .category-chip:hover,
  .category-chip.is-active {
    color: #222222;
    border-bottom-color: #222222;
  }

  .category-chip__icon {
    font-size: 1.5rem;
  }

  .category-chip__label {
    font-size: 0.88rem;
    font-weight: 500;
    white-space: nowrap;
  }

  .listing-zone {
    padding: 2.6rem 0 3rem;
  }

  .results-intro {
    margin-bottom: 2rem;
  }

  .results-intro h2 {
    margin: 0 0 0.4rem;
    font-size: 1.4rem;
    font-weight: 700;
  }

  .results-intro p {
    margin: 0;
    color: #6b7280;
  }

  .listing-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 2.3rem 1.75rem;
  }

  .listing-link {
    color: inherit;
    text-decoration: none;
  }

  .listing-card {
    display: block;
  }

  .listing-card__media {
    position: relative;
    border-radius: 1.6rem;
    overflow: hidden;
    aspect-ratio: 0.97 / 1;
    background: #f1f1f1;
    margin-bottom: 1rem;
  }

  .listing-card__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.35s ease;
  }

  .listing-link:hover .listing-card__media img {
    transform: scale(1.03);
  }

  .listing-card__badge {
    position: absolute;
    top: 0.95rem;
    left: 0.95rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.95);
    color: #222222;
    font-size: 0.88rem;
    font-weight: 600;
    padding: 0.4rem 0.75rem;
  }

  .listing-card__favorite {
    position: absolute;
    top: 1rem;
    right: 1rem;
    width: 2.2rem;
    height: 2.2rem;
    border-radius: 999px;
    background: rgba(0, 0, 0, 0.28);
    color: #ffffff;
    border: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
  }

  .listing-card__header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
  }

  .listing-card__location {
    font-size: 1.55rem;
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: -0.03em;
    margin-bottom: 0.45rem;
  }

  .listing-card__description {
    color: #6b7280;
    font-size: 1.03rem;
    line-height: 1.45;
    min-height: 3rem;
  }

  .listing-card__rating {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-weight: 600;
    white-space: nowrap;
    font-size: 1rem;
  }

  .listing-card__rating i {
    font-size: 0.88rem;
  }

  .listing-card__price {
    margin-top: 0.9rem;
    font-size: 1.1rem;
    color: #222222;
  }

  .listing-card__price strong {
    font-size: 1.7rem;
    letter-spacing: -0.04em;
  }

  .show-map-wrap {
    display: flex;
    justify-content: center;
    margin-top: 3rem;
  }

  .show-map-button {
    border: 1px solid #222222;
    border-radius: 999px;
    background: #ffffff;
    color: #222222;
    padding: 0.9rem 1.35rem;
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    font-weight: 600;
  }

  .show-map-button:hover {
    background: #f7f7f7;
  }

  .empty-state {
    padding: 4rem 0 5rem;
    text-align: center;
    color: #6b7280;
  }

  .empty-state i {
    font-size: 2.5rem;
    margin-bottom: 1rem;
    color: #ff385c;
  }

  @media (max-width: 1400px) {
    .listing-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (max-width: 992px) {
    .home-shell {
      padding: 0 1.25rem;
    }

    .hero-content {
      padding: 3.5rem 0 2.75rem;
    }

    .listing-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .hero-search__form {
      padding: 0.5rem 0.55rem 0.5rem 1rem;
    }

    .hero-search__input {
      font-size: 1.05rem;
    }

    .hero-search__submit {
      width: 3.35rem;
      height: 3.35rem;
    }

    .listing-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .listing-card__location {
      font-size: 1.25rem;
    }

    .listing-card__price strong {
      font-size: 1.35rem;
    }
  }
</style>

<div class="home-page">
  <section class="hero-band">
    <div class="home-shell hero-content">
      <h1 class="hero-title" data-animate="fade-up">Find your next adventure</h1>
      <p class="hero-subtitle" data-animate="fade-up" style="--reveal-delay: 0.08s;">Discover amazing places to stay around the world</p>

      <div class="hero-search" data-animate="zoom-in" style="--reveal-delay: 0.16s;">
        <form class="hero-search__form hero-glow" method="GET" action="/listings">
          <input
            type="text"
            class="hero-search__input"
            name="location"
            value="<%= searchLocation || "" %>"
            placeholder="Where are you going?"
            aria-label="Search by location"
          />
          <% if (selectedCategory && selectedCategory !== "all") { %>
            <input type="hidden" name="category" value="<%= selectedCategory %>" />
          <% } %>
          <button class="hero-search__submit" type="submit" aria-label="Search">
            <i class="fa-solid fa-magnifying-glass"></i>
          </button>
        </form>
      </div>
    </div>
  </section>

  <section class="category-strip">
    <div class="home-shell">
      <div class="category-strip__row" data-animate="fade-up">
        <% categories.forEach((category) => { %>
          <a
            class="category-chip <%= selectedCategory === category.value || (selectedCategory === "all" && category.value === "Trending") ? "is-active" : "" %>"
            href="/listings?<%= new URLSearchParams({ ...(searchLocation ? { location: searchLocation } : {}), category: category.value }).toString() %>"
          >
            <span class="category-chip__icon"><i class="<%= category.icon %>"></i></span>
            <span class="category-chip__label"><%= category.label %></span>
          </a>
        <% }) %>
      </div>
      <form method="GET" action="/listings" class="row g-3 pb-3">
        <div class="col-md-3">
          <input type="text" class="form-control" name="location" placeholder="Destination" value="<%= searchLocation || "" %>">
        </div>
        <div class="col-md-2">
          <input type="number" class="form-control" name="minPrice" placeholder="Min price" value="<%= filters?.minPrice || "" %>">
        </div>
        <div class="col-md-2">
          <input type="number" class="form-control" name="maxPrice" placeholder="Max price" value="<%= filters?.maxPrice || "" %>">
        </div>
        <div class="col-md-2">
          <input type="number" class="form-control" name="guests" placeholder="Guests" min="1" value="<%= filters?.guests || "" %>">
        </div>
        <div class="col-md-2">
          <input type="hidden" name="category" value="<%= selectedCategory || "all" %>">
          <button type="submit" class="btn btn-outline-dark w-100">Apply filters</button>
        </div>
        <div class="col-md-1">
          <a href="/listings" class="btn btn-link w-100 text-decoration-none">Clear</a>
        </div>
      </form>
    </div>
  </section>

  <section class="listing-zone">
    <div class="home-shell">
      <% if (searchLocation || (selectedCategory && selectedCategory !== "all")) { %>
        <div class="results-intro" data-animate="fade-up">
          <h2>
            <% if (searchLocation) { %>
              Results for "<%= searchLocation %>"
            <% } else { %>
              <%= selectedCategory %> stays
            <% } %>
          </h2>
          <p><%= allListings.length %> place<%= allListings.length === 1 ? "" : "s" %> found</p>
        </div>
      <% } %>

      <% if (allListings.length > 0) { %>
        <div class="listing-grid">
          <% allListings.forEach((listing, index) => { %>
            <article class="listing-card hover-float" data-animate="fade-up" style="--reveal-delay: <%= Math.min(index * 0.06, 0.3) %>s;">
                <div class="listing-card__media">
                  <a href="/listings/<%= listing._id %>" class="listing-link">
                    <img src="<%= listing.image.url %>" alt="<%= listing.title %>" />
                  </a>
                  <% if (listing.isGuestFavorite) { %>
                    <span class="listing-card__badge">Guest favourite</span>
                  <% } %>
                  <form action="/listings/<%= listing._id %>/favorite" method="POST">
                    <button type="submit" class="listing-card__favorite" aria-label="Save listing">
                      <i class="<%= favoriteIds.includes(listing._id.toString()) ? "fa-solid" : "fa-regular" %> fa-heart"></i>
                    </button>
                  </form>
                </div>

                <div class="listing-card__header">
                  <div>
                    <a href="/listings/<%= listing._id %>" class="listing-link">
                      <div class="listing-card__location"><%= listing.location %>, <%= listing.country %></div>
                      <div class="listing-card__description"><%= listing.title %></div>
                      <div class="text-muted small mt-1">Up to <%= listing.maxGuests || 4 %> guests</div>
                    </a>
                  </div>
                  <div class="listing-card__rating">
                    <i class="fa-solid fa-star"></i>
                    <span><%= listing.rating ? listing.rating.toFixed(2) : "5.00" %></span>
                  </div>
                </div>

                <div class="listing-card__price">
                  <strong>$<%= Number(listing.price).toLocaleString("en-US") %></strong> night
                </div>
            </article>
          <% }) %>
        </div>

        <div class="show-map-wrap" data-animate="fade-up" style="--reveal-delay: 0.12s;">
          <button type="button" class="show-map-button soft-float">
            <i class="fa-regular fa-map"></i>
            Show map
          </button>
        </div>
      <% } else { %>
        <div class="empty-state">
          <i class="fa-solid fa-location-dot"></i>
          <h2>No listings found</h2>
          <p>Try a different destination or switch categories to explore more places.</p>
        </div>
      <% } %>
    </div>
  </section>
</div>
