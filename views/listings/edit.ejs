<% layout("/layouts/boilerplate.ejs") %>

<style>
  .listing-form-page {
    background: linear-gradient(180deg, #f7f7f7 0%, #ffffff 100%);
    padding: 3rem 0 4rem;
  }

  .listing-form-shell {
    max-width: 960px;
    margin: 0 auto;
    padding: 0 1rem;
  }

  .listing-form-header {
    margin-bottom: 2rem;
  }

  .listing-form-header h1 {
    margin: 0 0 0.55rem;
    font-size: 2.8rem;
    font-weight: 700;
    letter-spacing: -0.05em;
    color: #222222;
  }

  .listing-form-header p {
    margin: 0;
    font-size: 1.15rem;
    color: #717171;
  }

  .listing-form-card {
    background: #ffffff;
    border-radius: 2rem;
    box-shadow: 0 18px 40px rgba(15, 23, 42, 0.12);
    padding: 2.2rem;
  }

  .listing-form .form-label {
    font-weight: 600;
    color: #222222;
    margin-bottom: 0.6rem;
  }

  .listing-form .form-control,
  .listing-form .form-select {
    border-radius: 1rem;
    padding: 0.95rem 1rem;
  }

  .listing-form textarea.form-control {
    min-height: 150px;
  }

  .current-image-preview {
    border-radius: 1rem;
    width: 100%;
    max-width: 320px;
    display: block;
    margin-bottom: 1rem;
    box-shadow: 0 8px 24px rgba(15, 23, 42, 0.12);
  }

  .listing-form-actions {
    display: flex;
    gap: 1rem;
    padding-top: 1rem;
  }

  .listing-form-actions .btn {
    flex: 1;
    border-radius: 1rem;
    padding: 1rem 1.25rem;
    font-weight: 700;
  }

  .listing-form-actions .btn-outline-dark:hover {
    background: #f7f7f7;
    color: #222222;
  }

  .listing-form-actions .btn-primary {
    background: #ff385c;
    border-color: #ff385c;
  }

  .listing-form-actions .btn-primary:hover {
    background: #e31c5f;
    border-color: #e31c5f;
  }
</style>

<div class="listing-form-page">
  <div class="listing-form-shell">
    <div class="listing-form-header" data-animate="fade-up">
      <h1>Edit your listing</h1>
      <p>Update your property details and keep your listing fresh</p>
    </div>

    <div class="listing-form-card" data-animate="zoom-in" style="--reveal-delay: 0.08s;">
      <form
        action="/listings/<%= listing._id %>?_method=PUT"
        method="post"
        novalidate
        class="listing-form needs-validation"
        enctype="multipart/form-data"
      >
        <div class="mb-4">
          <label for="title" class="form-label">Title</label>
          <input
            id="title"
            name="listing[title]"
            type="text"
            value="<%= listing.title %>"
            class="form-control"
            required
          />
        </div>

        <div class="mb-4">
          <label for="description" class="form-label">Description</label>
          <textarea id="description" name="listing[description]" class="form-control" required><%= listing.description %></textarea>
        </div>

        <div class="mb-4">
          <label for="category" class="form-label">Category</label>
          <select id="category" name="listing[category]" class="form-select">
            <option value="Trending" <%= listing.category === "Trending" ? "selected" : "" %>>Trending</option>
            <option value="Rooms" <%= listing.category === "Rooms" ? "selected" : "" %>>Rooms</option>
            <option value="Iconic Cities" <%= listing.category === "Iconic Cities" ? "selected" : "" %>>Iconic Cities</option>
            <option value="Mountains" <%= listing.category === "Mountains" ? "selected" : "" %>>Mountains</option>
            <option value="Castles" <%= listing.category === "Castles" ? "selected" : "" %>>Castles</option>
            <option value="Camping" <%= listing.category === "Camping" ? "selected" : "" %>>Camping</option>
            <option value="Farms" <%= listing.category === "Farms" ? "selected" : "" %>>Farms</option>
            <option value="Arctic" <%= listing.category === "Arctic" ? "selected" : "" %>>Arctic</option>
            <option value="Amazing Pools" <%= listing.category === "Amazing Pools" ? "selected" : "" %>>Amazing Pools</option>
            <option value="Domes" <%= listing.category === "Domes" ? "selected" : "" %>>Domes</option>
            <option value="Boats" <%= listing.category === "Boats" ? "selected" : "" %>>Boats</option>
          </select>
        </div>

        <div class="row g-4 mb-4">
          <div class="col-md-4">
            <label for="maxGuests" class="form-label">Guests</label>
            <input id="maxGuests" name="listing[maxGuests]" type="number" value="<%= listing.maxGuests || 4 %>" class="form-control" min="1" required />
          </div>
          <div class="col-md-4">
            <label for="bedrooms" class="form-label">Bedrooms</label>
            <input id="bedrooms" name="listing[bedrooms]" type="number" value="<%= listing.bedrooms || 2 %>" class="form-control" min="0" required />
          </div>
          <div class="col-md-4">
            <label for="bathrooms" class="form-label">Bathrooms</label>
            <input id="bathrooms" name="listing[bathrooms]" type="number" value="<%= listing.bathrooms || 2 %>" class="form-control" min="0" required />
          </div>
        </div>

        <div class="row g-4 mb-4">
          <div class="col-md-6">
            <label for="country" class="form-label">Country</label>
            <input
              id="country"
              name="listing[country]"
              type="text"
              value="<%= listing.country %>"
              class="form-control"
              required
            />
          </div>

          <div class="col-md-6">
            <label for="location" class="form-label">City/Location</label>
            <input
              id="location"
              name="listing[location]"
              type="text"
              value="<%= listing.location %>"
              class="form-control"
              required
            />
          </div>
        </div>

        <div class="mb-4">
          <label for="price" class="form-label">Price per night (USD)</label>
          <input
            id="price"
            name="listing[price]"
            type="number"
            value="<%= listing.price %>"
            class="form-control"
            required
          />
        </div>

        <div class="mb-4">
          <label for="amenities" class="form-label">Amenities</label>
          <input
            id="amenities"
            name="listing[amenities]"
            type="text"
            value="<%= (listing.amenities || []).join(', ') %>"
            class="form-control"
            placeholder="WiFi, Kitchen, Parking, TV"
          />
        </div>

        <div class="mb-4">
          <label class="form-label">Current image</label>
          <img src="<%= originalImageUrl %>" alt="Current listing image" class="current-image-preview" />
        </div>

        <div class="mb-4">
          <label for="image" class="form-label">Upload new image</label>
          <input id="image" name="listing[images]" type="file" class="form-control" multiple />
        </div>

        <div class="listing-form-actions">
          <a href="/listings/<%= listing._id %>" class="btn btn-outline-dark">Cancel</a>
          <button type="submit" class="btn btn-primary">Save Changes</button>
        </div>
      </form>
    </div>
  </div>
</div>
