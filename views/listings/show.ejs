<% layout("/layouts/boilerplate.ejs") %>

<style>
  .listing-hero {
    position: relative;
    height: 60vh;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    text-align: center;
    margin-bottom: 3rem;
  }

  .listing-hero-content h1 {
    font-size: 3rem;
    font-weight: 700;
    margin-bottom: 1rem;
    text-shadow: 2px 2px 4px rgba(0,0,0,0.3);
  }

  .listing-hero-content p {
    font-size: 1.2rem;
    opacity: 0.9;
    margin-bottom: 2rem;
  }

  .listing-hero-image {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: -1;
  }

  .listing-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .listing-main {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 4rem;
    margin-bottom: 4rem;
  }

  .listing-content {
    background: white;
    border-radius: 1rem;
    padding: 2rem;
    box-shadow: 0 4px 20px rgba(0,0,0,0.1);
  }

  .listing-header {
    border-bottom: 1px solid #ebebeb;
    padding-bottom: 2rem;
    margin-bottom: 2rem;
  }

  .listing-title {
    font-size: 2.5rem;
    font-weight: 700;
    color: #222222;
    margin-bottom: 1rem;
  }

  .listing-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .listing-rating {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .rating-stars {
    color: #ff385c;
  }

  .rating-text {
    color: #717171;
    font-weight: 500;
  }

  .listing-location {
    color: #717171;
    font-size: 1.1rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .listing-owner {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 2rem;
    padding: 1rem;
    background-color: #f7f7f7;
    border-radius: 1rem;
  }

  .owner-avatar {
    width: 3rem;
    height: 3rem;
    border-radius: 50%;
    background: linear-gradient(135deg, #ff385c, #e31c5f);
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-weight: 600;
    font-size: 1.2rem;
  }

  .owner-info h4 {
    margin: 0;
    color: #222222;
    font-size: 1.1rem;
  }

  .owner-info p {
    margin: 0;
    color: #717171;
    font-size: 0.9rem;
  }

  .listing-description {
    font-size: 1.1rem;
    line-height: 1.6;
    color: #222222;
    margin-bottom: 2rem;
  }

  .listing-amenities {
    margin-bottom: 2rem;
  }

  .amenities-title {
    font-size: 1.3rem;
    font-weight: 600;
    color: #222222;
    margin-bottom: 1rem;
  }

  .amenities-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1rem;
  }

  .amenity-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem;
    background-color: #f7f7f7;
    border-radius: 0.5rem;
  }

  .amenity-icon {
    color: #ff385c;
    width: 1.2rem;
  }

  .booking-widget {
    position: sticky;
    top: 2rem;
    background: white;
    border-radius: 1rem;
    padding: 2rem;
    box-shadow: 0 4px 20px rgba(0,0,0,0.1);
    border: 1px solid #ebebeb;
  }

  .booking-price {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .price-amount {
    font-size: 2rem;
    font-weight: 700;
    color: #222222;
  }

  .price-unit {
    color: #717171;
    font-size: 1rem;
  }

  .booking-form {
    margin-bottom: 1.5rem;
  }

  .form-group {
    margin-bottom: 1rem;
  }

  .form-label {
    display: block;
    font-weight: 600;
    color: #222222;
    margin-bottom: 0.5rem;
  }

  .form-control {
    width: 100%;
    padding: 0.75rem;
    border: 1px solid #ebebeb;
    border-radius: 0.5rem;
    font-size: 1rem;
    transition: border-color 0.2s;
  }

  .form-control:focus {
    outline: none;
    border-color: #ff385c;
    box-shadow: 0 0 0 2px rgba(255, 56, 92, 0.1);
  }

  .booking-button {
    width: 100%;
    background-color: #ff385c;
    color: white;
    border: none;
    border-radius: 0.5rem;
    padding: 1rem;
    font-size: 1.1rem;
    font-weight: 600;
    cursor: pointer;
    transition: background-color 0.2s;
  }

  .booking-button:hover {
    background-color: #e31c5f;
  }

  .booking-button:disabled {
    background-color: #717171;
    cursor: not-allowed;
  }

  .reviews-section {
    background: white;
    border-radius: 1rem;
    padding: 2rem;
    box-shadow: 0 4px 20px rgba(0,0,0,0.1);
    margin-bottom: 3rem;
  }

  .reviews-header {
    margin-bottom: 1rem;
    border-bottom: 1px solid #ebebeb;
    padding-bottom: 1rem;
  }

  .reviews-title {
    font-size: 1.5rem;
    font-weight: 600;
    color: #222222;
    margin: 0;
  }

  .view-all-reviews {
    background-color: #222222;
    color: white;
    border: none;
    border-radius: 0.5rem;
    padding: 0.75rem 1.5rem;
    font-weight: 600;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    transition: background-color 0.2s;
  }

  .view-all-reviews:hover {
    background-color: #000000;
    color: white;
  }

  .review-card {
    background: #f7f7f7;
    border-radius: 1rem;
    padding: 1.5rem;
    margin-bottom: 1.5rem;
    border: none;
  }

  .review-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 1rem;
  }

  .review-author {
    font-weight: 600;
    color: #222222;
    font-size: 1.1rem;
  }

  .review-rating {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .review-comment {
    color: #222222;
    line-height: 1.6;
    font-size: 1rem;
  }

  .map-section {
    background: white;
    border-radius: 1rem;
    padding: 2rem;
    box-shadow: 0 4px 20px rgba(0,0,0,0.1);
    margin-bottom: 3rem;
  }

  .map-title {
    font-size: 1.5rem;
    font-weight: 600;
    color: #222222;
    margin-bottom: 1.5rem;
  }

  #map {
    height: 400px;
    border-radius: 1rem;
    overflow: hidden;
  }

  .action-buttons {
    display: flex;
    gap: 1rem;
    margin-top: 2rem;
  }

  .btn-edit, .btn-delete {
    padding: 0.75rem 1.5rem;
    border-radius: 0.5rem;
    font-weight: 600;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    transition: all 0.2s;
  }

  .btn-edit {
    background-color: #222222;
    color: white;
    border: none;
  }

  .btn-edit:hover {
    background-color: #000000;
    color: white;
  }

  .btn-delete {
    background-color: #ff385c;
    color: white;
    border: none;
  }

  .btn-delete:hover {
    background-color: #e31c5f;
  }

  @media (max-width: 768px) {
    .listing-main {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    
    .listing-hero-content h1 {
      font-size: 2rem;
    }
    
    .listing-title {
      font-size: 2rem;
    }
    
    .booking-widget {
      position: static;
    }
    
    .listing-container {
      padding: 0 1rem;
    }
  }
</style>


<!-- Hero Section -->
<div class="listing-hero">
  <% if(listing.image && listing.image.url) { %>
    <img src="<%= listing.image.url %>" alt="<%= listing.title %>" class="listing-hero-image" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';">
  <% } %>
  <div class="listing-hero-fallback" style="display: none; position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); align-items: center; justify-content: center; color: white; font-size: 4rem;">
    <i class="fa-solid fa-image"></i>
  </div>
  <div class="listing-hero-content">
    <h1><%= listing.title %></h1>
    <p><%= listing.location %>, <%= listing.country %></p>
  </div>
</div>

<div class="listing-container">
  <div class="listing-main">
    <!-- Main Content -->
    <div class="listing-content">
      <!-- Header -->
      <div class="listing-header">
        <h1 class="listing-title"><%= listing.title %></h1>
        <div class="listing-meta">
          <div class="listing-rating">
            <div class="rating-stars">
              <% for(let i = 0; i < Math.floor(listing.rating); i++) { %>
                <i class="fa-solid fa-star"></i>
              <% } %>
              <% if(listing.rating % 1 !== 0) { %>
                <i class="fa-regular fa-star-half-stroke"></i>
              <% } %>
            </div>
            <span class="rating-text"><%= listing.rating %> · <%= listing.reviewCount %> reviews</span>
          </div>
        </div>
        <div class="listing-location">
          <i class="fa-solid fa-location-dot"></i>
          <span><%= listing.location %>, <%= listing.country %></span>
        </div>
      </div>

      <!-- Owner Info -->
      <div class="listing-owner">
        <div class="owner-avatar">
          <%= listing.owner.username.charAt(0).toUpperCase() %>
        </div>
        <div class="owner-info">
          <h4>Hosted by <%= listing.owner.username %></h4>
          <p>Superhost · 2 years hosting</p>
        </div>
      </div>

      <!-- Description -->
      <div class="listing-description">
        <p><%= listing.description %></p>
      </div>

      <!-- Amenities -->
      <div class="listing-amenities">
        <h3 class="amenities-title">What this place offers</h3>
        <div class="amenities-grid">
          <div class="amenity-item">
            <i class="fa-solid fa-wifi amenity-icon"></i>
            <span>WiFi</span>
          </div>
          <div class="amenity-item">
            <i class="fa-solid fa-car amenity-icon"></i>
            <span>Free parking</span>
          </div>
          <div class="amenity-item">
            <i class="fa-solid fa-snowflake amenity-icon"></i>
            <span>Air conditioning</span>
          </div>
          <div class="amenity-item">
            <i class="fa-solid fa-utensils amenity-icon"></i>
            <span>Kitchen</span>
          </div>
          <div class="amenity-item">
            <i class="fa-solid fa-dumbbell amenity-icon"></i>
            <span>Gym</span>
    </div>
          <div class="amenity-item">
            <i class="fa-solid fa-swimming-pool amenity-icon"></i>
            <span>Pool</span>
      </div>
    </div>
  </div>

      <!-- Action Buttons for Owner -->
<% if(currentUser && currentUser._id.equals(listing.owner._id)) { %>
        <div class="action-buttons">
          <a href="/listings/<%= listing._id %>/edit" class="btn-edit">
            <i class="fa-solid fa-edit"></i>
            Edit Listing
          </a>
          <form action="/listings/<%= listing._id %>?_method=DELETE" method="POST" style="display: inline;">
            <button type="submit" class="btn-delete" onclick="return confirm('Are you sure you want to delete this listing?')">
              <i class="fa-solid fa-trash"></i>
              Delete Listing
            </button>
    </form>
  </div>
<% } %>
    </div>

    <!-- Booking Widget -->
    <div class="booking-widget">
      <div class="booking-price">
        <span class="price-amount">₹<%= listing.price.toLocaleString("en-IN") %></span>
        <span class="price-unit">night</span>
      </div>
      
      <form class="booking-form" data-price="<%= listing.price %>">
        <div class="form-group">
          <label class="form-label">Check-in</label>
          <input type="date" class="form-control" name="checkin">
        </div>
        <div class="form-group">
          <label class="form-label">Check-out</label>
          <input type="date" class="form-control" name="checkout">
        </div>
        <div class="form-group">
          <label class="form-label">Guests</label>
          <select class="form-control" name="guests">
            <option value="1">1 guest</option>
            <option value="2">2 guests</option>
            <option value="3">3 guests</option>
            <option value="4">4 guests</option>
            <option value="5">5+ guests</option>
          </select>
        </div>
        <button type="submit" class="booking-button">
          Reserve
        </button>
      </form>
      
      <p style="text-align: center; color: #717171; font-size: 0.9rem; margin-top: 1rem;">
        You won't be charged yet
      </p>
    </div>
  </div>

  <!-- Reviews Section -->
  <div class="reviews-section">
    <div class="reviews-header">
      <h3 class="reviews-title">Reviews</h3>
    </div>
    
    <% if(listing.reviews.length > 0) { %>
      <div style="margin-bottom: 2rem;">
        <a href="/reviews?listing=<%= listing._id %>" class="view-all-reviews">
          <i class="fa-solid fa-star"></i>
          View All Reviews
        </a>
      </div>
    <% } %>

    <!-- Review Form -->
    <% if(currentUser) { %>
      <div class="review-form-section" style="margin-bottom: 2rem; padding: 2rem; background-color: #f7f7f7; border-radius: 1rem;">
        <h4 style="margin-bottom: 1.5rem; color: #222222;">Leave a Review</h4>
        <form action="/listings/<%= listing.id %>/reviews" method="post" novalidate class="needs-validation">
          <div class="form-group">
            <label for="title" class="form-label">Review Title</label>
            <input
              type="text"
              name="review[title]"
              id="title"
              class="form-control"
              placeholder="Summarize your experience"
              required
            />
            <div class="invalid-feedback">Please add a title for your review</div>
          </div>
         
          <div class="form-group">
        <label for="rating" class="form-label">Rating</label>
      <fieldset class="starability-slot">
        <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating." />
        <input type="radio" id="first-rate1" name="review[rating]" value="1" />
        <label for="first-rate1" title="Terrible">1 star</label>
        <input type="radio" id="first-rate2" name="review[rating]" value="2" />
        <label for="first-rate2" title="Not good">2 stars</label>
        <input type="radio" id="first-rate3" name="review[rating]" value="3" />
        <label for="first-rate3" title="Average">3 stars</label>
        <input type="radio" id="first-rate4" name="review[rating]" value="4" />
        <label for="first-rate4" title="Very good">4 stars</label>
        <input type="radio" id="first-rate5" name="review[rating]" value="5" />
        <label for="first-rate5" title="Amazing">5 stars</label>
      </fieldset>
    </div>
 
          <div class="form-group">
            <label for="experienceType" class="form-label">Experience Type</label>
            <select name="review[experienceType]" id="experienceType" class="form-control">
              <option value="Stays">Stays</option>
              <option value="Experiences">Experiences</option>
              <option value="Activities">Activities</option>
            </select>
          </div>

          <div class="form-group">
            <label for="stayDuration" class="form-label">Stay Duration (nights)</label>
            <input
              type="number"
              name="review[stayDuration]"
              id="stayDuration"
              class="form-control"
              min="1"
              placeholder="How many nights did you stay?"
            />
          </div>
     
          <div class="form-group">
        <label for="comment" class="form-label">Comments</label>
        <textarea
          name="review[comment]"
          id="comment"
          class="form-control"
          cols="30"
          rows="5"
              placeholder="Share your experience and what you loved about this place..."
          required
        ></textarea>
        <div class="invalid-feedback">Please add some reviews</div>
      </div>
          <button type="submit" class="booking-button">Submit Review</button>
    </form>
      </div>
    <% } %>
    
    <!-- Reviews List -->
    <% if(listing.reviews.length > 0) { %>
      <div class="reviews-list">
    <% for (review of listing.reviews) { %>
          <div class="review-card">
            <div class="review-header">
              <div class="review-author">@<%= review.author.username %></div>
              <div class="review-rating">
                <p class="starability-result" data-rating="<%= review.rating %>"></p>
                <span><%= review.rating %>.0</span>
              </div>
            </div>
            <div class="review-comment"><%= review.comment %></div>
            <% if(currentUser && review.author._id.equals(currentUser._id)) { %>
          <form
            action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE"
            method="post"
                style="margin-top: 1rem;"
          >
                <button type="submit" class="btn-delete" style="padding: 0.5rem 1rem; font-size: 0.9rem;" onclick="return confirm('Are you sure you want to delete this review?')">
                  <i class="fa-solid fa-trash"></i>
                  Delete Review
                </button>
          </form>
            <% } %>
          </div>
        <% } %>
        </div>
    <% } else { %>
      <div style="text-align: center; padding: 3rem; color: #717171;">
        <i class="fa-solid fa-star" style="font-size: 3rem; margin-bottom: 1rem; opacity: 0.5;"></i>
        <h4>No reviews yet</h4>
        <p>Be the first to share your experience!</p>
      </div>
    <% } %>
    </div>

  <!-- Map Section -->
  <div class="map-section">
    <h3 class="map-title">Where you'll be</h3>
    <div id="map" 
         data-map-token="<%= process.env.MAP_TOKEN %>"
         data-listing-coords="<%= JSON.stringify(listing.geometry.coordinates) %>"
         data-listing-title="<%= listing.title %>">
  </div>
  </div>
</div>

<script>
// Mapbox Map Initialization
document.addEventListener('DOMContentLoaded', function() {
  const mapElement = document.getElementById('map');
  if (mapElement && mapElement.dataset.mapToken && mapElement.dataset.listingCoords) {
    try {
      const mapToken = mapElement.dataset.mapToken;
      const coords = JSON.parse(mapElement.dataset.listingCoords);
      const title = mapElement.dataset.listingTitle || 'Listing Location';
      
      if (!mapToken) {
        console.error('Mapbox token not found');
        return;
      }
      
      if (!coords || !Array.isArray(coords) || coords.length !== 2) {
        console.error('Invalid coordinates:', coords);
        return;
      }
      
      mapboxgl.accessToken = mapToken;

      const map = new mapboxgl.Map({
        container: "map",
        style: 'mapbox://styles/mapbox/streets-v12',
        center: coords,
        zoom: 9,
      });

      const marker = new mapboxgl.Marker({ color: "red" })
        .setLngLat(coords)
        .setPopup(new mapboxgl.Popup({ offset: 25 }).setHTML(`<h4>${title}</h4><p>Exact location provided after booking.</p>`))
        .addTo(map);
        
    } catch (error) {
      console.error('Error initializing map:', error);
      mapElement.innerHTML = '<p style="text-align: center; color: #717171; padding: 2rem;">Map unavailable</p>';
    }
  } else {
    console.error('Map element or required data attributes not found');
  }
});
</script>

<script>
// Booking Widget Functionality
document.addEventListener('DOMContentLoaded', function() {
  const bookingForm = document.querySelector('.booking-form');
  const checkinInput = document.querySelector('input[name="checkin"]');
  const checkoutInput = document.querySelector('input[name="checkout"]');
  const guestsSelect = document.querySelector('select[name="guests"]');
  const bookingButton = document.querySelector('.booking-button');
  
  // Set minimum date to today
  const today = new Date().toISOString().split('T')[0];
  if (checkinInput) {
    checkinInput.min = today;
  }
  
  // Update checkout minimum date when checkin changes
  if (checkinInput && checkoutInput) {
    checkinInput.addEventListener('change', function() {
      const checkinDate = new Date(this.value);
      checkinDate.setDate(checkinDate.getDate() + 1);
      checkoutInput.min = checkinDate.toISOString().split('T')[0];
      
      // Clear checkout if it's before new minimum
      if (checkoutInput.value && new Date(checkoutInput.value) <= new Date(this.value)) {
        checkoutInput.value = '';
      }
    });
  }
  
  // Handle booking form submission
  if (bookingForm) {
    bookingForm.addEventListener('submit', function(e) {
      e.preventDefault();
      
      const checkin = checkinInput.value;
      const checkout = checkoutInput.value;
      const guests = guestsSelect.value;
      
      if (!checkin || !checkout) {
        alert('Please select both check-in and check-out dates');
        return;
      }
      
      if (new Date(checkout) <= new Date(checkin)) {
        alert('Check-out date must be after check-in date');
        return;
      }
      
      // Calculate nights
      const nights = Math.ceil((new Date(checkout) - new Date(checkin)) / (1000 * 60 * 60 * 24));
      const pricePerNight = parseInt(bookingForm.dataset.price);
      const totalPrice = nights * pricePerNight;
      
      // Show booking confirmation
      const confirmMessage = `Booking Details:
Check-in: ${checkin}
Check-out: ${checkout}
Guests: ${guests}
Nights: ${nights}
Price per night: ₹${pricePerNight.toLocaleString('en-IN')}
Total: ₹${totalPrice.toLocaleString('en-IN')}

Would you like to proceed with this booking?`;
      
      if (confirm(confirmMessage)) {
        // In a real application, this would redirect to payment/booking page
        alert('Booking functionality would be implemented here. Redirecting to payment...');
        // window.location.href = '/booking/checkout';
      }
    });
  }
  
  // Add smooth scrolling for anchor links
  document.querySelectorAll('a[href^="#"]').forEach(anchor => {
    anchor.addEventListener('click', function (e) {
      e.preventDefault();
      const target = document.querySelector(this.getAttribute('href'));
      if (target) {
        target.scrollIntoView({
          behavior: 'smooth',
          block: 'start'
        });
      }
    });
  });
  
  // Add loading state to booking button
  if (bookingButton) {
    bookingButton.addEventListener('click', function() {
      this.style.opacity = '0.7';
      this.style.cursor = 'not-allowed';
      
      setTimeout(() => {
        this.style.opacity = '1';
        this.style.cursor = 'pointer';
      }, 2000);
    });
  }
});
</script>