<% layout("/layouts/boilerplate.ejs") %>

<%
  const hostName = listing.owner?.username || "Wanderlust host";
  const amenityIconMap = {
    "WiFi": "fa-solid fa-wifi",
    "Kitchen": "fa-solid fa-door-open",
    "Parking": "fa-solid fa-car",
    "TV": "fa-solid fa-tv",
    "Air conditioning": "fa-solid fa-wind",
    "Heating": "fa-solid fa-fire",
    "Fireplace": "fa-solid fa-fire-flame-curved"
  };
  const amenityItems = (listing.amenities && listing.amenities.length ? listing.amenities : ["WiFi", "Kitchen", "Parking", "TV", "Air conditioning", "Heating"])
    .map((label) => ({ label, icon: amenityIconMap[label] || "fa-solid fa-circle-check" }));
  const galleryImages = listing.images && listing.images.length ? listing.images : [listing.image];
%>

<style>
  .listing-detail {
    background: #ffffff;
  }

  .listing-detail__hero {
    position: relative;
    height: 60vh;
    min-height: 440px;
    overflow: hidden;
    background: #0f172a;
  }

  .listing-detail__hero-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .listing-gallery {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .listing-gallery__item {
    border-radius: 1.25rem;
    overflow: hidden;
    aspect-ratio: 1.1 / 1;
    background: #f2f2f2;
  }

  .listing-gallery__item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .listing-detail__hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(15, 23, 42, 0.04) 0%, rgba(15, 23, 42, 0.72) 100%);
  }

  .listing-detail__hero-content {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    max-width: 2520px;
    margin: 0 auto;
    padding: 2.5rem 2rem 3rem;
    color: #ffffff;
  }

  .listing-detail__hero-title {
    margin: 0 0 0.7rem;
    font-size: clamp(2.4rem, 5vw, 4rem);
    line-height: 1.04;
    letter-spacing: -0.05em;
    font-weight: 600;
  }

  .listing-detail__hero-location {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    font-size: 1.15rem;
    color: rgba(255, 255, 255, 0.92);
  }

  .listing-detail__body {
    max-width: 2520px;
    margin: 0 auto;
    padding: 3rem 2rem 4rem;
  }

  .listing-detail__grid {
    display: grid;
    grid-template-columns: minmax(0, 2fr) minmax(320px, 1fr);
    gap: 3.5rem;
    align-items: start;
  }

  .listing-detail__main {
    min-width: 0;
  }

  .listing-detail__section {
    padding: 0 0 2.25rem;
    margin-bottom: 2.25rem;
    border-bottom: 1px solid #ebebeb;
  }

  .listing-detail__section:last-child {
    border-bottom: none;
    margin-bottom: 0;
    padding-bottom: 0;
  }

  .listing-host {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
  }

  .listing-host__main {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .listing-host__avatar {
    width: 4rem;
    height: 4rem;
    border-radius: 999px;
    background: linear-gradient(135deg, #ff385c 0%, #ff7a59 100%);
    color: #ffffff;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 1.25rem;
    font-weight: 700;
    flex-shrink: 0;
  }

  .listing-host__title {
    margin: 0 0 0.35rem;
    font-size: 1.45rem;
    font-weight: 700;
    color: #222222;
  }

  .listing-host__meta {
    color: #717171;
    font-size: 0.98rem;
  }

  .listing-host__badge {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    background: #ff385c;
    color: #ffffff;
    border-radius: 999px;
    padding: 0.55rem 0.9rem;
    font-weight: 600;
    white-space: nowrap;
  }

  .listing-detail__heading {
    margin: 0 0 1rem;
    font-size: 1.85rem;
    line-height: 1.2;
    letter-spacing: -0.03em;
    font-weight: 700;
    color: #222222;
  }

  .listing-detail__copy {
    color: #222222;
    line-height: 1.8;
    font-size: 1.02rem;
    max-width: 70ch;
  }

  .amenity-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .amenity-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    border: 1px solid #ebebeb;
    border-radius: 1rem;
    padding: 1rem 1.1rem;
    background: #ffffff;
  }

  .amenity-card i {
    font-size: 1.15rem;
    color: #222222;
    width: 1.35rem;
    text-align: center;
  }

  .reviews-summary {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    margin-bottom: 1.5rem;
  }

  .reviews-summary__star {
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 999px;
    background: #222222;
    color: #ffffff;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .reviews-summary__title {
    margin: 0;
    font-size: 1.75rem;
    font-weight: 700;
    color: #222222;
  }

  .review-compose {
    background: #f7f7f7;
    border-radius: 1.5rem;
    padding: 1.5rem;
    margin-bottom: 1.75rem;
  }

  .review-compose h4 {
    margin: 0 0 1rem;
    font-size: 1.1rem;
    font-weight: 700;
    color: #222222;
  }

  .review-compose__rating {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }

  .review-compose__stars {
    display: inline-flex;
    gap: 0.35rem;
  }

  .review-compose__star {
    border: none;
    background: none;
    color: #ff385c;
    font-size: 1.15rem;
  }

  .review-compose .form-control,
  .review-compose textarea {
    border-radius: 1rem;
    border-color: #e5e7eb;
  }

  .review-compose .btn {
    background: #ff385c;
    border: none;
    color: #ffffff;
    border-radius: 0.8rem;
    padding: 0.75rem 1.25rem;
    font-weight: 600;
  }

  .review-list {
    display: grid;
    gap: 1rem;
  }

  .review-card {
    background: #ffffff;
    border: 1px solid #ebebeb;
    border-radius: 1.35rem;
    padding: 1.3rem 1.4rem;
  }

  .review-card__top {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: flex-start;
    margin-bottom: 0.8rem;
  }

  .review-card__author {
    font-weight: 700;
    color: #222222;
    margin-bottom: 0.3rem;
  }

  .review-card__text {
    color: #222222;
    line-height: 1.7;
    margin-bottom: 0;
  }

  .map-preview {
    aspect-ratio: 16 / 9;
    border-radius: 1.5rem;
    background: #ebebeb;
    overflow: hidden;
    position: relative;
  }

  .map-preview #map {
    width: 100%;
    height: 100%;
  }

  .booking-card {
    position: sticky;
    top: 6.5rem;
    border: 1px solid #ebebeb;
    border-radius: 1.5rem;
    box-shadow: 0 12px 30px rgba(15, 23, 42, 0.08);
    padding: 1.6rem;
    background: #ffffff;
  }

  .booking-card__price-row {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .booking-card__price {
    font-size: 2rem;
    font-weight: 700;
    letter-spacing: -0.05em;
    color: #222222;
  }

  .booking-card__unit,
  .booking-card__meta {
    color: #717171;
  }

  .booking-card__meta {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    margin-bottom: 1.2rem;
    font-size: 0.95rem;
  }

  .booking-card__form {
    display: grid;
    gap: 0.9rem;
  }

  .booking-card__form .form-label {
    font-weight: 600;
    color: #222222;
  }

  .booking-card__form .form-control,
  .booking-card__form .form-select {
    border-radius: 0.95rem;
    padding: 0.85rem 0.95rem;
  }

  .booking-card__button {
    background: #ff385c;
    color: #ffffff;
    border: none;
    border-radius: 0.95rem;
    padding: 0.95rem 1rem;
    font-weight: 700;
    font-size: 1rem;
  }

  .booking-card__button:hover {
    background: #e31c5f;
  }

  .booking-card__note {
    margin: 1rem 0 0;
    text-align: center;
    color: #717171;
    font-size: 0.92rem;
  }

  .availability-list {
    margin-top: 1rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .availability-chip {
    background: #f7f7f7;
    border: 1px solid #ebebeb;
    border-radius: 999px;
    padding: 0.35rem 0.7rem;
    font-size: 0.8rem;
    color: #717171;
  }

  .owner-actions {
    display: flex;
    gap: 0.8rem;
    margin-top: 1.2rem;
    flex-wrap: wrap;
  }

  .owner-actions .btn {
    border-radius: 0.85rem;
    padding: 0.75rem 1.1rem;
    font-weight: 600;
  }

  .owner-actions .btn-dark {
    background: #222222;
  }

  .owner-actions .btn-danger {
    background: #ff385c;
    border-color: #ff385c;
  }

  @media (max-width: 1100px) {
    .listing-detail__grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .booking-card {
      position: static;
    }
  }

  @media (max-width: 768px) {
    .listing-detail__hero-content,
    .listing-detail__body {
      padding-left: 1.25rem;
      padding-right: 1.25rem;
    }

    .listing-host {
      flex-direction: column;
      align-items: flex-start;
    }

    .amenity-grid {
      grid-template-columns: 1fr;
    }

    .listing-gallery {
      grid-template-columns: 1fr;
    }

    .review-card__top {
      flex-direction: column;
    }
  }
</style>

<div class="listing-detail">
  <section class="listing-detail__hero">
    <img
      src="<%= listing.image.url %>"
      alt="<%= listing.title %>"
      class="listing-detail__hero-image"
    />
    <div class="listing-detail__hero-overlay"></div>
    <div class="listing-detail__hero-content">
      <h1 class="listing-detail__hero-title" data-animate="fade-up"><%= listing.title %></h1>
      <div class="listing-detail__hero-location" data-animate="fade-up" style="--reveal-delay: 0.08s;">
        <i class="fa-solid fa-location-dot"></i>
        <span><%= listing.location %>, <%= listing.country %></span>
      </div>
    </div>
  </section>

  <section class="listing-detail__body">
    <div class="listing-detail__grid">
      <div class="listing-detail__main">
        <section class="listing-detail__section" data-animate="fade-up">
          <div class="listing-host">
            <div class="listing-host__main">
              <div class="listing-host__avatar">
                <%= hostName.charAt(0).toUpperCase() %>
              </div>
              <div>
                <h2 class="listing-host__title">Hosted by <%= hostName %></h2>
                <div class="listing-host__meta">
                  <span>Up to <%= listing.maxGuests || 4 %> guests</span>
                  <span> · </span>
                  <span><%= listing.bedrooms || 2 %> bedrooms</span>
                  <span> · </span>
                  <span><%= listing.bathrooms || 2 %> bathrooms</span>
                </div>
              </div>
            </div>

            <div class="listing-host__badge">
              <i class="fa-solid fa-award"></i>
              <span>Superhost</span>
            </div>
          </div>

          <div class="listing-gallery">
            <% galleryImages.forEach((image) => { %>
              <div class="listing-gallery__item hover-float">
                <img src="<%= image.url %>" alt="<%= listing.title %> gallery image" />
              </div>
            <% }) %>
          </div>

          <% if(currentUser && listing.owner && currentUser._id.equals(listing.owner._id)) { %>
            <div class="owner-actions">
              <a href="/listings/<%= listing._id %>/edit" class="btn btn-dark">
                <i class="fa-solid fa-pen-to-square"></i> Edit Listing
              </a>
              <form action="/listings/<%= listing._id %>?_method=DELETE" method="POST">
                <button type="submit" class="btn btn-danger" onclick="return confirm('Are you sure you want to delete this listing?')">
                  <i class="fa-solid fa-trash"></i> Delete Listing
                </button>
              </form>
            </div>
          <% } %>
        </section>

        <section class="listing-detail__section" data-animate="fade-up" style="--reveal-delay: 0.04s;">
          <h3 class="listing-detail__heading">About this place</h3>
          <div class="listing-detail__copy">
            <p><%= listing.description %></p>
          </div>
        </section>

        <section class="listing-detail__section" data-animate="fade-up" style="--reveal-delay: 0.08s;">
          <h3 class="listing-detail__heading">What this place offers</h3>
          <div class="amenity-grid">
            <% amenityItems.forEach((amenity) => { %>
              <div class="amenity-card">
                <i class="<%= amenity.icon %>"></i>
                <span><%= amenity.label %></span>
              </div>
            <% }) %>
          </div>
        </section>

        <section class="listing-detail__section" data-animate="fade-up" style="--reveal-delay: 0.12s;">
          <div class="reviews-summary">
            <span class="reviews-summary__star">
              <i class="fa-solid fa-star"></i>
            </span>
            <h3 class="reviews-summary__title"><%= listing.rating %> · <%= listing.reviewCount %> reviews</h3>
          </div>

          <% if(currentUser) { %>
            <div class="review-compose">
              <h4>Leave a Review</h4>
              <form action="/listings/<%= listing._id %>/reviews" method="post" novalidate class="needs-validation">
                <div class="review-compose__rating">
                  <span class="text-muted">Rating:</span>
                  <div class="review-compose__stars">
                    <button type="button" class="review-compose__star"><i class="fa-solid fa-star"></i></button>
                    <button type="button" class="review-compose__star"><i class="fa-solid fa-star"></i></button>
                    <button type="button" class="review-compose__star"><i class="fa-solid fa-star"></i></button>
                    <button type="button" class="review-compose__star"><i class="fa-solid fa-star"></i></button>
                    <button type="button" class="review-compose__star"><i class="fa-solid fa-star"></i></button>
                  </div>
                </div>

                <div class="mb-3">
                  <label for="review-title" class="form-label">Title</label>
                  <input
                    type="text"
                    id="review-title"
                    name="review[title]"
                    class="form-control"
                    placeholder="Summarize your stay"
                    required
                  />
                </div>

                <div class="mb-3">
                  <label for="review-rating" class="form-label">Rating</label>
                  <select id="review-rating" name="review[rating]" class="form-select" required>
                    <option value="5">5 - Amazing</option>
                    <option value="4">4 - Great</option>
                    <option value="3">3 - Good</option>
                    <option value="2">2 - Fair</option>
                    <option value="1">1 - Poor</option>
                  </select>
                </div>

                <div class="mb-3">
                  <label for="review-comment" class="form-label">Your review</label>
                  <textarea
                    id="review-comment"
                    name="review[comment]"
                    class="form-control"
                    rows="5"
                    placeholder="Share your experience..."
                    required
                  ></textarea>
                </div>

                <button type="submit" class="btn">Submit Review</button>
              </form>
            </div>
          <% } %>

          <% if(listing.reviews.length > 0) { %>
            <div class="review-list">
              <% for (review of listing.reviews) { %>
                <article class="review-card hover-float">
                  <div class="review-card__top">
                    <div>
                      <div class="review-card__author"><%= review.author.username %></div>
                      <% if (review.title) { %>
                        <div class="text-muted small mb-2"><%= review.title %></div>
                      <% } %>
                    </div>

                    <div class="d-flex align-items-center gap-2">
                      <p class="starability-result mb-0" data-rating="<%= review.rating %>"></p>
                      <span class="fw-semibold"><%= review.rating %>.0</span>
                    </div>
                  </div>

                  <p class="review-card__text"><%= review.comment %></p>

                  <% if(currentUser && review.author._id.equals(currentUser._id)) { %>
                    <form action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE" method="post" class="mt-3">
                      <button type="submit" class="btn btn-outline-danger btn-sm" onclick="return confirm('Are you sure you want to delete this review?')">
                        Delete Review
                      </button>
                    </form>
                  <% } %>
                </article>
              <% } %>
            </div>
          <% } else { %>
            <p class="text-muted mb-0">No reviews yet. Be the first to share your experience.</p>
          <% } %>
        </section>

        <section class="listing-detail__section" data-animate="fade-up" style="--reveal-delay: 0.16s;">
          <h3 class="listing-detail__heading">Where you'll be</h3>
          <div class="map-preview">
            <div
              id="map"
              data-map-token="<%= process.env.MAP_TOKEN %>"
              data-listing-coords="<%= JSON.stringify(listing.geometry.coordinates) %>"
              data-listing-title="<%= listing.title %>"
            ></div>
          </div>
        </section>
      </div>

      <aside>
        <div class="booking-card" data-animate="fade-left">
          <% if (currentUser) { %>
            <form action="/listings/<%= listing._id %>/favorite" method="POST" class="mb-3">
              <button type="submit" class="btn btn-outline-dark w-100 rounded-pill">
                <i class="<%= isFavorite ? "fa-solid" : "fa-regular" %> fa-heart"></i>
                <%= isFavorite ? "Saved to favorites" : "Save to favorites" %>
              </button>
            </form>
          <% } %>

          <div class="booking-card__price-row">
            <span class="booking-card__price">$<%= Number(listing.price).toLocaleString("en-US") %></span>
            <span class="booking-card__unit">night</span>
          </div>

          <div class="booking-card__meta">
            <i class="fa-solid fa-star"></i>
            <span><%= listing.rating %></span>
            <span>·</span>
            <span><%= listing.reviewCount %> reviews</span>
          </div>

          <form class="booking-card__form" data-price="<%= listing.price %>" action="/listings/<%= listing._id %>/bookings" method="POST">
            <div>
              <label class="form-label" for="checkin">Check-in</label>
              <input id="checkin" type="date" class="form-control" name="booking[checkIn]" />
            </div>

            <div>
              <label class="form-label" for="checkout">Check-out</label>
              <input id="checkout" type="date" class="form-control" name="booking[checkOut]" />
            </div>

            <div>
              <label class="form-label" for="guests">Guests</label>
              <select id="guests" class="form-select" name="booking[guests]">
                <option value="1">1 guest</option>
                <option value="2">2 guests</option>
                <option value="3">3 guests</option>
                <option value="4">4 guests</option>
                <option value="5">5+ guests</option>
              </select>
            </div>

            <button type="submit" class="booking-card__button">Reserve</button>
          </form>

          <p class="booking-card__note">You won't be charged yet</p>

          <% if (listing.bookings && listing.bookings.length > 0) { %>
            <div class="mt-3">
              <div class="fw-semibold mb-2">Booked dates</div>
              <div class="availability-list">
                <% listing.bookings.slice(0, 6).forEach((booking) => { %>
                  <span class="availability-chip">
                    <%= new Date(booking.checkIn).toLocaleDateString("en-US", { month: "short", day: "numeric" }) %>
                    -
                    <%= new Date(booking.checkOut).toLocaleDateString("en-US", { month: "short", day: "numeric" }) %>
                  </span>
                <% }) %>
              </div>
            </div>
          <% } %>
        </div>
      </aside>
    </div>
  </section>
</div>

<script>
  document.addEventListener("DOMContentLoaded", function () {
    const mapElement = document.getElementById("map");

    if (mapElement && mapElement.dataset.mapToken && mapElement.dataset.listingCoords) {
      try {
        const mapToken = mapElement.dataset.mapToken;
        const coords = JSON.parse(mapElement.dataset.listingCoords);
        const title = mapElement.dataset.listingTitle || "Listing Location";

        if (mapToken && Array.isArray(coords) && coords.length === 2) {
          mapboxgl.accessToken = mapToken;

          const map = new mapboxgl.Map({
            container: "map",
            style: "mapbox://styles/mapbox/streets-v12",
            center: coords,
            zoom: 9,
          });

          new mapboxgl.Marker({ color: "#ff385c" })
            .setLngLat(coords)
            .setPopup(
              new mapboxgl.Popup({ offset: 25 }).setHTML(
                "<h4>" + title + "</h4><p>Exact location provided after booking.</p>"
              )
            )
            .addTo(map);
        }
      } catch (error) {
        mapElement.innerHTML =
          '<div class="d-flex h-100 align-items-center justify-content-center text-muted">Map unavailable</div>';
      }
    }

    const bookingForm = document.querySelector(".booking-card__form");
    const checkinInput = document.querySelector('input[name="booking[checkIn]"]');
    const checkoutInput = document.querySelector('input[name="booking[checkOut]"]');
    const guestsSelect = document.querySelector('select[name="booking[guests]"]');

    if (checkinInput) {
      const today = new Date().toISOString().split("T")[0];
      checkinInput.min = today;
    }

    if (checkinInput && checkoutInput) {
      checkinInput.addEventListener("change", function () {
        const checkinDate = new Date(this.value);
        checkinDate.setDate(checkinDate.getDate() + 1);
        checkoutInput.min = checkinDate.toISOString().split("T")[0];

        if (checkoutInput.value && new Date(checkoutInput.value) <= new Date(this.value)) {
          checkoutInput.value = "";
        }
      });
    }

    if (bookingForm) {
      bookingForm.addEventListener("submit", function (e) {
        e.preventDefault();

        const checkin = checkinInput.value;
        const checkout = checkoutInput.value;
        const guests = guestsSelect.value;

        if (!checkin || !checkout) {
          alert("Please select both check-in and check-out dates");
          return;
        }

        if (new Date(checkout) <= new Date(checkin)) {
          alert("Check-out date must be after check-in date");
          return;
        }

        const nights = Math.ceil((new Date(checkout) - new Date(checkin)) / (1000 * 60 * 60 * 24));
        const pricePerNight = parseInt(bookingForm.dataset.price, 10);
        const totalPrice = nights * pricePerNight;

        const confirmMessage =
          "Booking Details:\n" +
          "Check-in: " + checkin + "\n" +
          "Check-out: " + checkout + "\n" +
          "Guests: " + guests + "\n" +
          "Nights: " + nights + "\n" +
          "Price per night: $" + pricePerNight.toLocaleString("en-US") + "\n" +
          "Total: $" + totalPrice.toLocaleString("en-US") + "\n\n" +
          "Would you like to proceed with this booking?";

        if (confirm(confirmMessage)) {
          bookingForm.submit();
        }
      });
    }
  });
</script>
