<style>
  .navbar {
    height: 5rem;
    background-color: white;
    border-bottom: 1px solid #ebebeb;
    padding: 0 2rem;
  }

  .navbar-brand {
    font-size: 1.5rem;
    font-weight: 600;
    color: #ff385c !important;
  }

  .nav-tabs {
    border: none;
    margin-left: 2rem;
  }

  .nav-tabs .nav-link {
    border: none;
    color: #222222;
    font-weight: 500;
    padding: 1rem 1.5rem;
    margin-right: 0.5rem;
  }

  .nav-tabs .nav-link.active {
    color: #222222;
    border-bottom: 2px solid #222222;
    background: none;
  }

  .nav-tabs .nav-link:hover {
    border-bottom: 2px solid #ebebeb;
  }

  .user-controls {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .user-controls .nav-link {
    color: #222222;
    font-weight: 500;
    padding: 0.5rem 1rem;
    border-radius: 2rem;
    transition: background-color 0.2s;
  }

  .user-controls .nav-link:hover {
    background-color: #f7f7f7;
  }

  .user-controls .btn-primary {
    background-color: #ff385c;
    border: none;
    border-radius: 2rem;
    padding: 0.5rem 1rem;
    font-weight: 500;
  }

  .user-controls .btn-primary:hover {
    background-color: #e31c5f;
  }

  .user-menu {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem;
    border: 1px solid #ebebeb;
    border-radius: 2rem;
    cursor: pointer;
    transition: box-shadow 0.2s;
    position: relative;
  }

  .user-menu:hover {
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
  }

  .user-avatar {
    width: 2rem;
    height: 2rem;
    border-radius: 50%;
    background-color: #ff385c;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-weight: 600;
  }

  .user-dropdown {
    position: absolute;
    top: 100%;
    right: 0;
    background: white;
    border: 1px solid #ebebeb;
    border-radius: 1rem;
    box-shadow: 0 4px 20px rgba(0,0,0,0.1);
    min-width: 200px;
    z-index: 1000;
    display: none;
    margin-top: 0.5rem;
  }

  .user-dropdown.show {
    display: block;
  }

  .dropdown-item {
    padding: 0.75rem 1rem;
    color: #222222;
    text-decoration: none;
    display: block;
    transition: background-color 0.2s;
  }

  .dropdown-item:hover {
    background-color: #f7f7f7;
    text-decoration: none;
    color: #222222;
  }

  .dropdown-divider {
    height: 1px;
    background-color: #ebebeb;
    margin: 0.5rem 0;
  }
</style>

<nav class="navbar navbar-expand-lg">
  <div class="container-fluid">
    <!-- Logo -->
    <a class="navbar-brand" href="/listings">
      <i class="fa-regular fa-compass"></i> WanderLust
    </a>

    <!-- Navigation Tabs -->
    <ul class="nav nav-tabs">
      <li class="nav-item">
        <a class="nav-link active" href="/listings">Stays</a>
      </li>
      <li class="nav-item">
        <a class="nav-link" href="#">Experiences</a>
      </li>
    </ul>

    <!-- User Controls -->
    <div class="user-controls">
      <% if (!currentUser) { %>
        <a class="nav-link" href="/listings/new">WanderLust your home</a>
        <a class="btn btn-primary" href="/signup">Sign up</a>
        <a class="nav-link" href="/login">Log in</a>
      <% } %>
      <% if (currentUser) { %>
        <a class="nav-link" href="/listings/new">WanderLust your home</a>
        <div class="user-menu" onclick="toggleDropdown()">
          <i class="fa-solid fa-bars"></i>
          <div class="user-avatar">
            <%= currentUser.username.charAt(0).toUpperCase() %>
          </div>
          <div class="user-dropdown" id="userDropdown">
            <a href="/profile" class="dropdown-item">
              <i class="fa-solid fa-user"></i> Profile
            </a>
            <a href="/bookings" class="dropdown-item">
              <i class="fa-solid fa-calendar"></i> My Bookings
            </a>
            <a href="/listings/new" class="dropdown-item">
              <i class="fa-solid fa-plus"></i> Add Listing
            </a>
            <div class="dropdown-divider"></div>
            <a href="/logout" class="dropdown-item">
              <i class="fa-solid fa-sign-out-alt"></i> Log out
            </a>
          </div>
        </div>
      <% } %>
    </div>
  </div>
</nav>

<script>
function toggleDropdown() {
  const dropdown = document.getElementById('userDropdown');
  dropdown.classList.toggle('show');
}

// Close dropdown when clicking outside
document.addEventListener('click', function(event) {
  const userMenu = document.querySelector('.user-menu');
  const dropdown = document.getElementById('userDropdown');
  
  if (!userMenu.contains(event.target)) {
    dropdown.classList.remove('show');
  }
});
</script>
