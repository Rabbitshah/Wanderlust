<style>
  .site-navbar {
    position: sticky;
    top: 0;
    z-index: 1000;
    background: rgba(255, 255, 255, 0.96);
    backdrop-filter: blur(14px);
    border-bottom: 1px solid #ebebeb;
  }

  .site-navbar__inner {
    max-width: 2520px;
    margin: 0 auto;
    padding: 1.35rem 2rem;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 1.5rem;
  }

  .site-navbar__brand {
    display: inline-flex;
    align-items: center;
    gap: 0.85rem;
    text-decoration: none;
    color: #222222;
    font-weight: 600;
    font-size: 1.85rem;
    justify-self: start;
  }

  .site-navbar__brand:hover {
    color: #222222;
  }

  .brand-mark {
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 999px;
    border: 2px solid #ff385c;
    color: #ff385c;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 1rem;
  }

  .brand-wordmark {
    font-size: 1.9rem;
    letter-spacing: -0.04em;
  }

  .site-navbar__tabs {
    display: inline-flex;
    align-items: center;
    gap: 1.75rem;
    justify-self: center;
  }

  .site-navbar__tab {
    color: #6b7280;
    text-decoration: none;
    font-weight: 600;
    padding-bottom: 0.6rem;
    border-bottom: 2px solid transparent;
  }

  .site-navbar__tab:hover,
  .site-navbar__tab.is-active {
    color: #222222;
    border-bottom-color: #222222;
  }

  .site-navbar__actions {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 1.5rem;
    justify-self: end;
  }

  .site-navbar__link,
  .site-navbar__button {
    color: #222222;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.98rem;
  }

  .site-navbar__button {
    border: none;
    background: none;
  }

  .site-navbar__host {
    white-space: nowrap;
  }

  .site-navbar__auth {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .site-navbar__menu {
    position: relative;
  }

  .site-navbar__menu-trigger {
    border: 1px solid #dcdcdc;
    background: #fff;
    border-radius: 999px;
    padding: 0.4rem 0.5rem 0.4rem 0.85rem;
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    box-shadow: 0 1px 2px rgba(15, 23, 42, 0.06);
  }

  .site-navbar__menu-trigger:hover {
    box-shadow: 0 6px 18px rgba(15, 23, 42, 0.12);
  }

  .site-navbar__avatar {
    width: 2rem;
    height: 2rem;
    border-radius: 999px;
    background: #ff385c;
    color: #fff;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 0.9rem;
  }

  .site-navbar__dropdown {
    position: absolute;
    top: calc(100% + 0.8rem);
    right: 0;
    min-width: 220px;
    background: #fff;
    border: 1px solid #ebebeb;
    border-radius: 1.25rem;
    box-shadow: 0 18px 35px rgba(15, 23, 42, 0.16);
    padding: 0.5rem;
    display: none;
  }

  .site-navbar__dropdown.show {
    display: block;
  }

  .site-navbar__dropdown a {
    display: block;
    padding: 0.8rem 0.95rem;
    border-radius: 0.9rem;
    color: #222222;
    text-decoration: none;
    font-weight: 500;
  }

  .site-navbar__dropdown a:hover {
    background: #f7f7f7;
  }

  .site-navbar__divider {
    height: 1px;
    background: #ebebeb;
    margin: 0.45rem 0;
  }

  @media (max-width: 992px) {
    .site-navbar__inner {
      grid-template-columns: 1fr;
      justify-items: center;
      text-align: center;
      padding: 1rem 1.25rem;
    }

    .site-navbar__brand,
    .site-navbar__actions {
      justify-self: center;
    }

    .site-navbar__actions {
      flex-wrap: wrap;
      justify-content: center;
    }
  }

  @media (max-width: 576px) {
    .site-navbar__tabs {
      gap: 1rem;
    }

    .brand-wordmark {
      font-size: 1.55rem;
    }

    .site-navbar__actions {
      gap: 1rem;
    }
  }
</style>

<nav class="site-navbar">
  <div class="site-navbar__inner">
    <a class="site-navbar__brand" href="/listings">
      <span class="brand-mark">
        <i class="fa-regular fa-compass"></i>
      </span>
      <span class="brand-wordmark">Wanderlust</span>
    </a>

    <div class="site-navbar__tabs">
      <a class="site-navbar__tab <%= currentPath && currentPath.startsWith('/listings') ? 'is-active' : '' %>" href="/listings">Stays</a>
      <a class="site-navbar__tab <%= currentPath === '/experiences' ? 'is-active' : '' %>" href="/experiences">Experiences</a>
    </div>

    <div class="site-navbar__actions">
      <a class="site-navbar__link site-navbar__host" href="/listings/new">Wanderlust your home</a>
      <% if (!currentUser) { %>
        <div class="site-navbar__auth">
          <a class="site-navbar__link" href="/signup">Sign up</a>
          <a class="site-navbar__link" href="/login">Log in</a>
        </div>
      <% } else { %>
        <div class="site-navbar__menu">
          <button type="button" class="site-navbar__menu-trigger" onclick="toggleDropdown(event)">
            <i class="fa-solid fa-bars"></i>
            <span class="site-navbar__avatar"><%= currentUser.username.charAt(0).toUpperCase() %></span>
          </button>
          <div class="site-navbar__dropdown" id="userDropdown">
            <a href="/listings/new">Add listing</a>
            <a href="/reviews">Reviews</a>
            <div class="site-navbar__divider"></div>
            <a href="/logout">Log out</a>
          </div>
        </div>
      <% } %>
    </div>
  </div>
</nav>

<script>
  function toggleDropdown(event) {
    event.stopPropagation();
    const dropdown = document.getElementById("userDropdown");
    if (dropdown) {
      dropdown.classList.toggle("show");
    }
  }

  document.addEventListener("click", function (event) {
    const menu = document.querySelector(".site-navbar__menu");
    const dropdown = document.getElementById("userDropdown");

    if (menu && dropdown && !menu.contains(event.target)) {
      dropdown.classList.remove("show");
    }
  });
</script>
