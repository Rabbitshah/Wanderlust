<% layout("/layouts/boilerplate.ejs") %>

<style>
  .reviews-page {
    background: #ffffff;
    padding: 3rem 0 4rem;
  }

  .reviews-shell {
    max-width: 2520px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .reviews-header {
    margin-bottom: 2rem;
  }

  .reviews-header h1 {
    margin: 0 0 0.5rem;
    font-size: 2.9rem;
    font-weight: 700;
    letter-spacing: -0.05em;
    color: #222222;
  }

  .reviews-header p {
    margin: 0;
    color: #717171;
    font-size: 1.15rem;
  }

  .reviews-filters {
    background: #f7f7f7;
    border-radius: 1.5rem;
    padding: 1.5rem;
    margin-bottom: 2rem;
  }

  .reviews-filters__top {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    margin-bottom: 1.25rem;
    color: #222222;
  }

  .reviews-filters__count {
    min-width: 1.65rem;
    height: 1.65rem;
    padding: 0 0.45rem;
    border-radius: 999px;
    background: #ff385c;
    color: #ffffff;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 0.8rem;
    font-weight: 700;
  }

  .reviews-filters .form-select {
    border-radius: 1rem;
    background-color: #ffffff;
  }

  .reviews-filters .form-check-label {
    color: #222222;
  }

  .reviews-filters__clear {
    margin-top: 1rem;
    color: #717171;
    text-decoration: none;
    font-weight: 500;
  }

  .reviews-summary {
    margin-bottom: 1.5rem;
    color: #717171;
  }

  .reviews-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.5rem;
  }

  .review-tile {
    border: 1px solid #ebebeb;
    border-radius: 1.5rem;
    padding: 1.5rem;
    background: #ffffff;
    transition: box-shadow 0.2s ease, transform 0.2s ease;
  }

  .review-tile:hover {
    box-shadow: 0 12px 30px rgba(15, 23, 42, 0.1);
    transform: translateY(-2px);
  }

  .review-tile__top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .review-tile__author {
    display: flex;
    align-items: center;
    gap: 0.85rem;
  }

  .review-tile__avatar {
    width: 3rem;
    height: 3rem;
    border-radius: 999px;
    background: #ff385c;
    color: #ffffff;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
  }

  .review-tile__name {
    font-weight: 700;
    color: #222222;
  }

  .review-tile__date {
    color: #717171;
    font-size: 0.9rem;
  }

  .review-tile__badges {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 0.9rem;
  }

  .review-chip {
    display: inline-flex;
    align-items: center;
    border-radius: 999px;
    padding: 0.35rem 0.7rem;
    font-size: 0.8rem;
    font-weight: 600;
  }

  .review-chip--featured {
    background: #ff385c;
    color: #ffffff;
  }

  .review-chip--outline {
    border: 1px solid #d1d5db;
    color: #222222;
    background: #ffffff;
  }

  .review-chip--verified {
    background: #eef2ff;
    color: #374151;
  }

  .review-tile__content {
    color: #222222;
    line-height: 1.75;
    margin-bottom: 1rem;
  }

  .review-tile__link {
    color: #717171;
    text-decoration: underline;
  }

  .reviews-empty {
    text-align: center;
    padding: 5rem 1rem;
  }

  .reviews-empty i {
    font-size: 3rem;
    color: #ebebeb;
    margin-bottom: 1rem;
  }

  .reviews-pagination {
    display: flex;
    justify-content: center;
    gap: 0.75rem;
    margin-top: 2.5rem;
    flex-wrap: wrap;
  }

  .reviews-pagination .btn {
    border-radius: 0.8rem;
    min-width: 2.75rem;
  }

  @media (max-width: 992px) {
    .reviews-shell {
      padding: 0 1.25rem;
    }

    .reviews-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<%
  const activeFiltersCount = [
    filters.experienceType,
    filters.rating,
    filters.verified === "true",
    filters.featured === "true",
  ].filter(Boolean).length;
%>

<div class="reviews-page">
  <div class="reviews-shell">
    <div class="reviews-header" data-animate="fade-up">
      <h1>Guest Reviews</h1>
      <p>Real experiences from verified guests</p>
    </div>

    <div class="reviews-filters" data-animate="zoom-in" style="--reveal-delay: 0.06s;">
      <div class="reviews-filters__top">
        <i class="fa-solid fa-filter"></i>
        <h2 class="h5 mb-0">Filters</h2>
        <% if (activeFiltersCount > 0) { %>
          <span class="reviews-filters__count"><%= activeFiltersCount %></span>
        <% } %>
      </div>

      <form method="GET" action="/reviews">
        <div class="row g-3 align-items-end">
          <div class="col-md-3">
            <label for="experienceType" class="form-label">Experience Type</label>
            <select name="experienceType" id="experienceType" class="form-select">
              <option value="">All</option>
              <option value="Stays" <%= filters.experienceType === "Stays" ? "selected" : "" %>>Stays</option>
              <option value="Experiences" <%= filters.experienceType === "Experiences" ? "selected" : "" %>>Experiences</option>
              <option value="Activities" <%= filters.experienceType === "Activities" ? "selected" : "" %>>Activities</option>
            </select>
          </div>

          <div class="col-md-3">
            <label for="rating" class="form-label">Minimum Rating</label>
            <select name="rating" id="rating" class="form-select">
              <option value="">All ratings</option>
              <option value="5" <%= filters.rating === "5" ? "selected" : "" %>>5 stars</option>
              <option value="4" <%= filters.rating === "4" ? "selected" : "" %>>4+ stars</option>
              <option value="3" <%= filters.rating === "3" ? "selected" : "" %>>3+ stars</option>
            </select>
          </div>

          <div class="col-md-2">
            <div class="form-check mb-2">
              <input class="form-check-input" type="checkbox" name="verified" value="true" id="verified" <%= filters.verified === "true" ? "checked" : "" %>>
              <label class="form-check-label" for="verified">Verified only</label>
            </div>
          </div>

          <div class="col-md-2">
            <div class="form-check mb-2">
              <input class="form-check-input" type="checkbox" name="featured" value="true" id="featured" <%= filters.featured === "true" ? "checked" : "" %>>
              <label class="form-check-label" for="featured">Featured only</label>
            </div>
          </div>

          <div class="col-md-2 d-grid">
            <button type="submit" class="btn btn-primary">Apply</button>
          </div>
        </div>

        <% if (activeFiltersCount > 0) { %>
          <a href="/reviews" class="reviews-filters__clear d-inline-block">Clear all filters</a>
        <% } %>
      </form>
    </div>

    <div class="reviews-summary">
      Showing <%= reviews.length %> of <%= totalReviews %> reviews
    </div>

    <% if (reviews.length > 0) { %>
      <div class="reviews-grid">
        <% reviews.forEach((review, index) => { %>
          <article class="review-tile hover-float" data-animate="fade-up" style="--reveal-delay: <%= Math.min(index * 0.05, 0.25) %>s;">
            <div class="review-tile__top">
              <div class="review-tile__author">
                <div class="review-tile__avatar"><%= review.author.username.charAt(0).toUpperCase() %></div>
                <div>
                  <div class="review-tile__name"><%= review.author.username %></div>
                  <div class="review-tile__date"><%= new Date(review.createdAt).toLocaleDateString() %></div>
                </div>
              </div>

              <div class="d-flex align-items-center gap-2">
                <p class="starability-result mb-0" data-rating="<%= review.rating %>"></p>
              </div>
            </div>

            <div class="review-tile__badges">
              <% if (review.isVerified) { %>
                <span class="review-chip review-chip--verified">Verified</span>
              <% } %>
              <% if (review.isFeatured) { %>
                <span class="review-chip review-chip--featured">Featured</span>
              <% } %>
              <span class="review-chip review-chip--outline"><%= review.experienceType %></span>
            </div>

            <% if (review.title) { %>
              <h3 class="h5 mb-2"><%= review.title %></h3>
            <% } %>

            <p class="review-tile__content"><%= review.comment %></p>

            <a href="/listings/<%= review.listing._id %>" class="review-tile__link">
              View listing: <%= review.listing.title %>
            </a>
          </article>
        <% }) %>
      </div>
    <% } else { %>
      <div class="reviews-empty">
        <i class="fa-solid fa-star"></i>
        <h2>No reviews found</h2>
        <p class="text-muted mb-4">Try adjusting your filters.</p>
        <a href="/reviews" class="btn btn-primary">Clear filters</a>
      </div>
    <% } %>

    <% if (totalPages > 1) { %>
      <div class="reviews-pagination">
        <% if (currentPage > 1) { %>
          <a href="/reviews?page=<%= currentPage - 1 %><%= Object.keys(filters).map(key => `&${key}=${filters[key]}`).join('') %>" class="btn btn-outline-secondary">Previous</a>
        <% } %>
        <% for(let i = Math.max(1, currentPage - 2); i <= Math.min(totalPages, currentPage + 2); i++) { %>
          <a href="/reviews?page=<%= i %><%= Object.keys(filters).map(key => `&${key}=${filters[key]}`).join('') %>" class="btn <%= i === currentPage ? "btn-primary" : "btn-outline-secondary" %>"><%= i %></a>
        <% } %>
        <% if (currentPage < totalPages) { %>
          <a href="/reviews?page=<%= currentPage + 1 %><%= Object.keys(filters).map(key => `&${key}=${filters[key]}`).join('') %>" class="btn btn-outline-secondary">Next</a>
        <% } %>
      </div>
    <% } %>
  </div>
</div>
